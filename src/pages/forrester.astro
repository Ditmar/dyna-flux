      /* ── Model Settings modal ── */
      #settings-modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        z-index: 9999;
        align-items: center;
        justify-content: center;
      }
      #settings-modal-box {
        background: #1e1e1e;
        border-radius: 10px;
        padding: 22px 26px 18px;
        width: 400px;
        max-width: 92vw;
        box-shadow: 0 16px 48px rgba(0,0,0,0.75);
