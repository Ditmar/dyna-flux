        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        line-height: 1;
        text-align: center;
      }
      .settings-dt-btn:nth-child(4n)   { border-right: none; }
      .settings-dt-btn:nth-child(n+5)  { border-bottom: none; }
      .settings-dt-btn:hover:not(.active) { background: #1a2d45; color: #9cdcfe; }
      .settings-dt-btn.active { background: #1d4ed8; color: #fff; font-weight: 600; }
      .settings-footer {
