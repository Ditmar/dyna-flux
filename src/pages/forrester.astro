      }
      .settings-input::-webkit-inner-spin-button,
      .settings-input::-webkit-outer-spin-button { -webkit-appearance: none; }
      .settings-input:focus { border-color: #007acc; box-shadow: 0 0 0 1px #007acc; }
      .settings-dt-group {
        display: grid;
