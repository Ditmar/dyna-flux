      }
      .settings-footer button {
        padding: 6px 18px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        font-size: 0.82rem;
        font-weight: 500;
        transition: opacity 0.15s;
      }
      .settings-footer button:hover { opacity: 0.82; }
    </style>
    <title>
      System Dynamics Diagram Editor: Storage, Flows, Control Factors | GoJS
      Diagramming Library
    </title>
  </head>

  <body>
    <div class='flex flex-col prose'>
      <div class='w-full max-w-screen-xl mx-auto'>
        <!-- * * * * * * * * * * * * * -->
        <!-- Start of GoJS sample code -->
        <script src='/release/go.js' is:inline></script>
        <div id='allSampleContent' class='p-4 w-full'>
          <script src='/assets/extensions/Figures.js' is:inline></script>
          <script src='/assets/extensions/NodeLabelDraggingTool.js' is:inline
          ></script>
          <script id='code'>
            // SD is a global variable, to avoid polluting global namespace and to make the global
            // nature of the individual variables obvious.
            var SD = {
              mode: 'pointer', // Set to default mode.  Alternatives are "node" and "link", for
              // adding a new node or a new link respectively.
              itemType: 'pointer', // Set when user clicks on a node or link button.
              nodeCounter: { stock: 0, cloud: 0, variable: 0, valve: 0 },
            };
            var myDiagram; // Declared as global
            var currentFormulaNodeKey = null;
            var currentFormulaProp = 'formula'; // 'formula' | 'initialValue'
            var saveTimer = null;
            var STORAGE_KEY = 'dyna-flux:diagram';
            var SETTINGS_KEY = 'dyna-flux:settings';
            var _formulaAllVars = [];
            var _pendingDt = 1;
            var modelSettings = { initTime: 0, finalTime: 100, dt: 1 };

            // Returns true if the formula references model variables (this.xxx)
            function isDynamic(formula) {
              return Boolean(formula && /\bthis\./.test(formula));
            }

            function insertAtCursor(text) {
              var ta    = document.getElementById('formula-input');
              var start = ta.selectionStart;
              var end   = ta.selectionEnd;
              ta.value  = ta.value.substring(0, start) + text + ta.value.substring(end);
              ta.selectionStart = ta.selectionEnd = start + text.length;
              ta.focus();
            }

            // propName: 'formula' (valve/variable) | 'initialValue' (stock)
            // category: 'stock' | 'valve' | 'variable'
            function openFormulaModal(nodeKey, nodeLabel, currentValue, propName, category) {
              currentFormulaNodeKey = nodeKey;
              currentFormulaProp    = propName || 'formula';

              var isInitVal = currentFormulaProp === 'initialValue';
              document.getElementById('formula-modal-prefix').textContent =
                isInitVal ? 'Initial value' : 'Formula';
              document.getElementById('formula-node-label').textContent = nodeLabel;

              var modelJson = JSON.parse(myDiagram.model.toJson());
              var allNodes  = modelJson.nodeDataArray || [];
              var allLinks  = modelJson.linkDataArray || [];
              var nodeMap   = {};
              allNodes.forEach(function(n) { nodeMap[n.key] = n; });

              var relatedVars = [];

              if (category === 'stock') {
                // For stocks: show all other stocks and variables as possible initial value refs
                allNodes.forEach(function(n) {
                  if ((n.category === 'stock' || n.category === 'variable') && n.key !== nodeKey) {
                    relatedVars.push({ varName: 'this.' + toVarName(n.label || n.key), display: n.label || n.key });
                  }
                });
              } else {
                // For valve/variable: filter by incoming influence arrows
                var influencerKeys = {};
                allLinks.forEach(function(l) {
                  if (l.category === 'influence' && l.to === nodeKey) influencerKeys[l.from] = true;
                });
                var hasInfluences = Object.keys(influencerKeys).length > 0;
                if (hasInfluences) {
                  Object.keys(influencerKeys).forEach(function(key) {
                    var n = nodeMap[key];
                    if (n && (n.category === 'stock' || n.category === 'variable')) {
                      relatedVars.push({ varName: 'this.' + toVarName(n.label || n.key), display: n.label || n.key });
                    }
                  });
                } else {
                  allNodes.forEach(function(n) {
                    if (n.category === 'stock' || n.category === 'variable') {
                      relatedVars.push({ varName: 'this.' + toVarName(n.label || n.key), display: n.label || n.key });
                    }
                  });
                }
              }

              var shadows = [
                { varName: 'this.time',      display: 'time' },
                { varName: 'this.dt',        display: 'dt' },
                { varName: 'this.finalTime', display: 'finalTime' },
              ];

              // Store all vars for live search filtering
              _formulaAllVars = relatedVars.map(function(v) {
                return { varName: v.varName, display: v.display, isShadow: false };
              }).concat(shadows.map(function(v) {
                return { varName: v.varName, display: v.display, isShadow: true };
              }));

              var searchEl = document.getElementById('formula-vars-search');
              if (searchEl) searchEl.value = '';
              renderFormulaBadges('');

              var input = document.getElementById('formula-input');
              input.value = currentValue || '';
              input.placeholder = isInitVal
                ? 'e.g. 100  or  this.otherVar * 2'
                : 'e.g. this.alpha * this.prey';
              document.getElementById('formula-modal').style.display = 'flex';
              setTimeout(function() {
                if (searchEl && _formulaAllVars.length > 0) {
                  searchEl.focus();
                } else {
                  input.focus();
                  input.setSelectionRange(input.value.length, input.value.length);
                }
              }, 30);
            }

            function saveFormula() {
              if (currentFormulaNodeKey === null) return;
              var value = document.getElementById('formula-input').value;
              var node = myDiagram.findNodeForKey(currentFormulaNodeKey);
              if (node) {
                myDiagram.startTransaction('set ' + currentFormulaProp);
                myDiagram.model.setDataProperty(node.data, currentFormulaProp, value.trim());
                myDiagram.commitTransaction('set ' + currentFormulaProp);
              }
              closeFormulaModal();
            }

            function closeFormulaModal() {
              document.getElementById('formula-modal').style.display = 'none';
              currentFormulaNodeKey = null;
            }

            function renderFormulaBadges(query) {
              var container = document.getElementById('formula-vars-container');
              var countEl   = document.getElementById('formula-vars-count');
              container.innerHTML = '';

              var q            = (query || '').toLowerCase().trim();
              var relFiltered  = _formulaAllVars.filter(function(v) { return !v.isShadow  && (!q || v.display.toLowerCase().indexOf(q) !== -1); });
              var shadFiltered = _formulaAllVars.filter(function(v) { return  v.isShadow  && (!q || v.display.toLowerCase().indexOf(q) !== -1); });
              var total        = _formulaAllVars.filter(function(v) { return !v.isShadow; }).length;
              var visible      = relFiltered.length + shadFiltered.length;

              if (countEl) {
                countEl.textContent = q
                  ? visible + ' / ' + _formulaAllVars.length
                  : total + (total === 1 ? ' var' : ' vars');
              }

              if (visible === 0) {
                var empty = document.createElement('span');
                empty.className = 'formula-vars-empty';
                empty.textContent = 'No matches';
                container.appendChild(empty);
                return;
              }

              relFiltered.forEach(function(v) {
                var b = document.createElement('button');
                b.type = 'button'; b.className = 'formula-var-badge'; b.tabIndex = -1;
                b.textContent = v.display; b.title = v.varName;
                b.onclick = function() { insertAtCursor(v.varName); };
                container.appendChild(b);
              });

              if (relFiltered.length > 0 && shadFiltered.length > 0) {
                var sep = document.createElement('span');
                sep.className = 'formula-var-sep'; sep.textContent = '|';
                container.appendChild(sep);
              }

              shadFiltered.forEach(function(v) {
                var b = document.createElement('button');
                b.type = 'button'; b.className = 'formula-var-badge formula-var-badge--shadow'; b.tabIndex = -1;
                b.textContent = v.display; b.title = v.varName;
                b.onclick = function() { insertAtCursor(v.varName); };
                container.appendChild(b);
              });
            }

            /* ── fx function catalog ── */
            var FX_FUNCTIONS = [
              // Time
              { cat: 'Time', name: 'PULSE',       sig: 'PULSE(start, width, this.time)',                          desc: 'Returns 1 during [start, start+width), 0 otherwise',                      snippet: 'PULSE(10, 1, this.time)' },
              { cat: 'Time', name: 'PULSE_TRAIN',  sig: 'PULSE_TRAIN(start, width, interval, end, this.time)',     desc: 'Repeating pulses of given width at regular intervals',                     snippet: 'PULSE_TRAIN(0, 1, 5, 100, this.time)' },
              { cat: 'Time', name: 'RAMP',         sig: 'RAMP(slope, start_time, this.time)',                     desc: 'Linear ramp starting at start_time, rate = slope/time unit',              snippet: 'RAMP(1, 10, this.time)' },
              { cat: 'Time', name: 'STEP',         sig: 'STEP(height, step_time, this.time)',                     desc: 'Jumps from 0 to height at step_time',                                     snippet: 'STEP(1, 10, this.time)' },
              // Logic
              { cat: 'Logic', name: 'IF_THEN_ELSE', sig: 'IF_THEN_ELSE(condition, a, b)',                         desc: 'Returns a when condition is true, b otherwise',                           snippet: 'IF_THEN_ELSE(this.x > 0, this.x, 0)' },
              { cat: 'Logic', name: 'CLIP',         sig: 'CLIP(x, lo, hi)',                                       desc: 'Clamps x to the range [lo, hi]',                                          snippet: 'CLIP(this.x, 0, 100)' },
              { cat: 'Logic', name: 'XIDZ',         sig: 'XIDZ(x, y, z)',                                        desc: 'x / y; returns z if y is zero',                                           snippet: 'XIDZ(this.a, this.b, 0)' },
              { cat: 'Logic', name: 'ZIDZ',         sig: 'ZIDZ(x, y)',                                           desc: 'x / y; returns 0 if y is zero',                                           snippet: 'ZIDZ(this.a, this.b)' },
              // Math
              { cat: 'Math', name: 'ABS',           sig: 'ABS(x)',                                               desc: 'Absolute value',                                                          snippet: 'ABS(this.x)' },
              { cat: 'Math', name: 'LN',            sig: 'LN(x)',                                                 desc: 'Natural logarithm (base e)',                                               snippet: 'LN(this.x)' },
              { cat: 'Math', name: 'EXP',           sig: 'EXP(x)',                                               desc: 'Exponential — e raised to x',                                             snippet: 'EXP(this.x)' },
              { cat: 'Math', name: 'SQRT',          sig: 'SQRT(x)',                                               desc: 'Square root',                                                             snippet: 'SQRT(this.x)' },
              { cat: 'Math', name: 'SIN',           sig: 'SIN(x)',                                               desc: 'Sine of x (radians)',                                                      snippet: 'SIN(this.x)' },
              { cat: 'Math', name: 'COS',           sig: 'COS(x)',                                               desc: 'Cosine of x (radians)',                                                    snippet: 'COS(this.x)' },
              { cat: 'Math', name: 'INTEGER',       sig: 'INTEGER(x)',                                           desc: 'Floor of x to nearest integer',                                           snippet: 'INTEGER(this.x)' },
              { cat: 'Math', name: 'MODULO',        sig: 'MODULO(x, m)',                                         desc: 'x modulo m — always non-negative',                                        snippet: 'MODULO(this.x, 10)' },
              { cat: 'Math', name: 'RANDOM_UNIFORM',sig: 'RANDOM_UNIFORM(min, max)',                              desc: 'Uniform random number in [min, max)',                                      snippet: 'RANDOM_UNIFORM(0, 1)' },
              // Delay / Smooth
              { cat: 'Delay / Smooth', name: 'SMOOTH',  sig: "SMOOTH('id', input, avgTime, this.time, this.dt, init)",  desc: 'First-order exponential smoothing — low-pass filter',            snippet: "SMOOTH('s1', this.x, 5, this.time, this.dt, 0)" },
              { cat: 'Delay / Smooth', name: 'DELAY1',  sig: "DELAY1('id', input, delayTime, this.time, this.dt, init)", desc: 'First-order exponential delay',                                  snippet: "DELAY1('d1', this.x, 5, this.time, this.dt, 0)" },
              { cat: 'Delay / Smooth', name: 'DELAY3',  sig: "DELAY3('id', input, delayTime, this.time, this.dt, init)", desc: 'Third-order pipeline delay — sharper, less distorted response', snippet: "DELAY3('d3', this.x, 5, this.time, this.dt, 0)" },
              { cat: 'Delay / Smooth', name: 'TREND',   sig: "TREND('id', input, avgTime, this.time, this.dt)",         desc: 'Relative rate of change: (input − smooth) / (smooth × avgTime)', snippet: "TREND('t1', this.x, 5, this.time, this.dt)" },
            ];

            function openFxModal() {
              var searchEl = document.getElementById('fx-search');
              if (searchEl) searchEl.value = '';
              renderFxList('');
              document.getElementById('fx-modal').style.display = 'flex';
              setTimeout(function() { if (searchEl) searchEl.focus(); }, 30);
            }

            function closeFxModal() {
              document.getElementById('fx-modal').style.display = 'none';
            }

            function renderFxList(query) {
              var list = document.getElementById('fx-list');
              list.innerHTML = '';
              var q = (query || '').toLowerCase().trim();

              var cats = [];
              var catMap = {};
              FX_FUNCTIONS.forEach(function(fn) {
                if (q && fn.name.toLowerCase().indexOf(q) === -1 && fn.desc.toLowerCase().indexOf(q) === -1 && fn.sig.toLowerCase().indexOf(q) === -1) return;
                if (!catMap[fn.cat]) { catMap[fn.cat] = []; cats.push(fn.cat); }
                catMap[fn.cat].push(fn);
              });

              if (cats.length === 0) {
                var empty = document.createElement('div');
                empty.style.cssText = 'color:#555; font-size:0.75rem; padding:14px 4px; font-style:italic;';
                empty.textContent = 'No functions match "' + query + '"';
                list.appendChild(empty);
                return;
              }

              cats.forEach(function(cat) {
                var label = document.createElement('div');
                label.className = 'fx-category-label';
                label.textContent = cat;
                list.appendChild(label);

                catMap[cat].forEach(function(fn) {
                  var item = document.createElement('div');
                  item.className = 'fx-item';

                  var info = document.createElement('div');
                  info.className = 'fx-item-info';

                  var sig = document.createElement('div');
                  sig.className = 'fx-item-sig';
                  sig.textContent = fn.sig;
                  sig.title = fn.snippet;

                  var desc = document.createElement('div');
                  desc.className = 'fx-item-desc';
                  desc.textContent = fn.desc;

                  info.appendChild(sig);
                  info.appendChild(desc);

                  var btn = document.createElement('button');
                  btn.type = 'button';
                  btn.className = 'fx-item-insert';
                  btn.textContent = 'Insert';
                  btn.onclick = function(e) { e.stopPropagation(); insertFxSnippet(fn.snippet); };

                  item.onclick = function() { insertFxSnippet(fn.snippet); };
                  item.appendChild(info);
                  item.appendChild(btn);
                  list.appendChild(item);
                });
              });
            }

            function insertFxSnippet(snippet) {
              insertAtCursor(snippet);
              closeFxModal();
              setTimeout(function() { document.getElementById('formula-input').focus(); }, 30);
            }

            /* ── Model Settings ── */
            function loadSettings() {
              try {
                var saved = localStorage.getItem(SETTINGS_KEY);
                if (saved) {
                  var s = JSON.parse(saved);
                  if (typeof s.initTime  === 'number') modelSettings.initTime  = s.initTime;
                  if (typeof s.finalTime === 'number') modelSettings.finalTime = s.finalTime;
                  if (typeof s.dt        === 'number') modelSettings.dt        = s.dt;
                }
              } catch(e) {}
              updateSettingsToolbarHint();
            }

            function openSettingsModal() {
              _pendingDt = modelSettings.dt;
              document.getElementById('settings-init-time').value  = modelSettings.initTime;
              document.getElementById('settings-final-time').value = modelSettings.finalTime;
              updateDtButtons(_pendingDt);
              document.getElementById('settings-modal').style.display = 'flex';
              setTimeout(function() { document.getElementById('settings-final-time').focus(); }, 30);
            }

            function closeSettingsModal() {
              document.getElementById('settings-modal').style.display = 'none';
            }

            function selectDt(val) {
              _pendingDt = val;
              updateDtButtons(val);
            }

            function updateDtButtons(val) {
              var btns = document.querySelectorAll('.settings-dt-btn');
              btns.forEach(function(btn) {
                btn.classList.toggle('active', parseFloat(btn.getAttribute('data-dt')) === val);
              });
            }

            function saveSettings() {
              var initTime  = parseFloat(document.getElementById('settings-init-time').value);
              var finalTime = parseFloat(document.getElementById('settings-final-time').value);
              if (isNaN(initTime))  initTime  = 0;
              if (isNaN(finalTime) || finalTime <= initTime) finalTime = initTime + 100;
              modelSettings.initTime  = initTime;
              modelSettings.finalTime = finalTime;
              modelSettings.dt        = _pendingDt;
              try { localStorage.setItem(SETTINGS_KEY, JSON.stringify(modelSettings)); } catch(e) {}
              updateSettingsToolbarHint();
              closeSettingsModal();
            }

            function updateSettingsToolbarHint() {
              var hint = document.getElementById('settings-hint');
              if (hint) hint.textContent = 'T=' + modelSettings.finalTime + ' · dt=' + modelSettings.dt;
            }

            // Convert any user-facing label into a valid JS identifier.
            // "tasa de nacimientos" → "tasa_de_nacimientos"
            // "población (t)"       → "poblacion_t"
            // "2ndStock"            → "_2ndStock"
            function toVarName(label) {
              var s = (label || '')
                .trim()
                .normalize('NFD')
                .replace(/[̀-ͯ]/g, '')    // strip accent marks: á→a, ñ→n, ü→u
                .replace(/[^a-zA-Z0-9_$]+/g, '_')  // any run of invalid chars → single _
                .replace(/^_+|_+$/g, '')            // trim outer underscores
                .replace(/^(\d)/, '_$1');           // can't start with digit
              return s || 'unnamed';
            }

            function init() {
              myDiagram = new go.Diagram('myDiagramDiv', {
                'undoManager.isEnabled': true,
                allowLink: false, // linking is only started via buttons, not modelessly
                'animationManager.isEnabled': false,

                'linkingTool.portGravity': 0, // no snapping while drawing new links
                'linkingTool.doActivate': function () {
                  // an override must be function, not using an arrow
                  // change the curve of the LinkingTool.temporaryLink
                  this.temporaryLink.curve =
                    SD.itemType === 'flow' ? go.Curve.None : go.Curve.Bezier;
                  this.temporaryLink.path.stroke =
                    SD.itemType === 'flow' ? 'blue' : 'green';
                  this.temporaryLink.path.strokeWidth =
                    SD.itemType === 'flow' ? 5 : 1;
                  go.LinkingTool.prototype.doActivate.call(this);
                },
                // override the link creation process
                'linkingTool.insertLink': function (
                  fromnode,
                  fromport,
                  tonode,
                  toport
                ) {
                  // method override must be function, not =>
                  // to control what kind of Link is created,
                  // change the LinkingTool.archetypeLinkData's category
                  myDiagram.model.setCategoryForLinkData(
                    this.archetypeLinkData,
                    SD.itemType
                  );
                  // Whenever a new Link is drawn by the LinkingTool, it also adds a node data object
                  // that acts as the label node for the link, to allow links to be drawn to/from the link.
                  this.archetypeLabelNodeData =
                    SD.itemType === 'flow' ? { category: 'valve' } : null;
                  // also change the text indicating the condition, which the user can edit
                  this.archetypeLinkData.text = SD.itemType;
                  return go.LinkingTool.prototype.insertLink.call(
                    this,
                    fromnode,
                    fromport,
                    tonode,
                    toport
                  );
                },

                'clickCreatingTool.archetypeNodeData': {}, // enable ClickCreatingTool
                'clickCreatingTool.isDoubleClick': false, // operates on a single click in background
                // but only in "node" creation mode
                'clickCreatingTool.canStart': function () {
                  // method override must be function, not =>
                  return (
                    SD.mode === 'node' &&
                    go.ClickCreatingTool.prototype.canStart.call(this)
                  );
                },
                // customize the data for the new node
                'clickCreatingTool.insertPart': function (loc) {
                  // method override must be function, not =>
                  SD.nodeCounter[SD.itemType] += 1;
                  var newNodeId = SD.itemType + SD.nodeCounter[SD.itemType];
                  this.archetypeNodeData = {
                    key: newNodeId,
                    category: SD.itemType,
                    label: newNodeId,
                  };
                  return go.ClickCreatingTool.prototype.insertPart.call(
                    this,
                    loc
                  );
                },
              });

              // install the NodeLabelDraggingTool as a "mouse move" tool
              myDiagram.toolManager.mouseMoveTools.insertAt(
                0,
                new NodeLabelDraggingTool()
              );

              // update title/button when modified state changes
              myDiagram.addDiagramListener('Modified', (e) => {
                var button = document.getElementById('SaveButton');
                if (button) button.disabled = !myDiagram.isModified;
                var idx = document.title.indexOf('*');
                if (myDiagram.isModified) {
                  if (idx < 0) document.title += '*';
                } else {
                  if (idx >= 0) document.title = document.title.slice(0, idx);
                }
              });

              // Debounced autosave — fires after every committed transaction,
              // not just when isModified changes (which only triggers once per session)
              myDiagram.addModelChangedListener(function(e) {
                if (!e.isTransactionFinished) return;
                if (saveTimer) clearTimeout(saveTimer);
                saveTimer = setTimeout(function() {
                  try { localStorage.setItem(STORAGE_KEY, myDiagram.model.toJson()); } catch(e) {}
                }, 400);
              });

              // generate unique label for valve on newly-created flow link
              myDiagram.addDiagramListener('LinkDrawn', (e) => {
                var link = e.subject;
                if (link.category === 'flow') {
                  myDiagram.startTransaction('updateNode');
                  SD.nodeCounter.valve += 1;
                  var newNodeId = 'flow' + SD.nodeCounter.valve;
                  var labelNode = link.labelNodes.first();
                  myDiagram.model.setDataProperty(
                    labelNode.data,
                    'label',
                    newNodeId
                  );
                  myDiagram.commitTransaction('updateNode');
                }
              });

              buildTemplates();

              load();
              loadSettings();
              setMode('pointer', 'pointer');

              document.getElementById('formula-input').addEventListener('keydown', function(e) {
                if (e.key === 'Escape') closeFormulaModal();
                if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) saveFormula();
              });
              document.getElementById('formula-vars-search').addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                  if (this.value) { this.value = ''; renderFormulaBadges(''); }
                  else closeFormulaModal();
                }
                if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) saveFormula();
              });
            }

            function buildTemplates() {
              // helper functions for the templates
              function nodeStyle(obj) {
                const partial = {
                  type: go.Panel.Spot,
                  layerName: 'Background',
                  locationObjectName: 'SHAPE',
                  selectionObjectName: 'SHAPE',
                  locationSpot: go.Spot.Center,
                };

                if (!obj) return partial;
                Object.entries(partial).forEach(([prop, val]) => {
                  obj[prop] ??= val;
                });

                return obj;
              }

              function shapeStyle(obj) {
                const partial = {
                  name: 'SHAPE',
                  stroke: 'black',
                  fill: '#f0f0f0',
                  portId: '', // So a link can be dragged from the Node: see /GraphObject.html#portId
                  fromLinkable: true,
                  toLinkable: true,
                };
                if (!obj) return partial;
                Object.entries(partial).forEach(([prop, val]) => {
                  if (obj[prop] !== undefined) return; // some properties may intentionally be set to null
                  obj[prop] = val;
                });

                return obj;
              }

              function textStyle(obj) {
                Object.assign(obj, {
                  font: 'bold 11pt helvetica, bold arial, sans-serif',
                  margin: 2,
                  editable: true,
                });
                obj.bindTwoWay('text', 'label');

                return obj;
              }

              // Node templates
              myDiagram.nodeTemplateMap.add(
                'stock',
                new go.Node(nodeStyle())
                  .add(
                    new go.Shape({
                      desiredSize: new go.Size(50, 30),
                      doubleClick: function(e, shape) {
                        var node = shape.part;
                        openFormulaModal(
                          node.data.key,
                          node.data.label || node.data.key,
                          node.data.initialValue || '',
                          'initialValue',
                          'stock'
                        );
                      },
                    })
                    .set(shapeStyle())
                    .bind('fill', 'initialValue', function(v) {
                      return (v !== undefined && v !== null && String(v).trim()) ? '#fff9c4' : '#f0f0f0';
                    }),
                    textStyle(
                      new go.TextBlock({
                        _isNodeLabel: true,
                        alignment: new go.Spot(0.5, 0.5, 0, 30),
                      }).bindTwoWay(
                        'alignment',
                        'label_offset',
                        go.Spot.parse,
                        go.Spot.stringify
                      )
                    )
                  )
                  .bindTwoWay(
                    'location',
                    'loc',
                    go.Point.parse,
                    go.Point.stringify
                  )
              );

              myDiagram.nodeTemplateMap.add(
                'cloud',
                new go.Node(nodeStyle())
                  .bindTwoWay(
                    'location',
                    'loc',
                    go.Point.parse,
                    go.Point.stringify
                  )
                  .add(
                    new go.Shape(shapeStyle(), {
                      figure: 'Cloud',
                      desiredSize: new go.Size(35, 35),
                    })
                  )
              );

              myDiagram.nodeTemplateMap.add(
                'valve',
                new go.Node(
                  nodeStyle({
                    movable: false,
                    layerName: 'Foreground',
                    alignmentFocus: go.Spot.None,
                  })
                )
                  .bindTwoWay(
                    'location',
                    'loc',
                    go.Point.parse,
                    go.Point.stringify
                  )
                  .add(
                    new go.Shape({
                      figure: 'Ellipse',
                      desiredSize: new go.Size(20, 20),
                      doubleClick: function(e, shape) {
                        var node = shape.part;
                        openFormulaModal(node.data.key, node.data.label || node.data.key, node.data.formula || '', 'formula', 'valve');
                      },
                    })
                    .set(shapeStyle())
                    .bind('fill', 'formula', function(f) {
                      return (f && f.trim()) ? '#a5d6a7' : '#f0f0f0';
                    }),
                    textStyle(
                      new go.TextBlock({
                        _isNodeLabel: true,
                        alignment: new go.Spot(0.5, 0.5, 0, 20),
                      }).bindTwoWay(
                        'alignment',
                        'label_offset',
                        go.Spot.parse,
                        go.Spot.stringify
                      )
                    )
                  )
              );

              myDiagram.nodeTemplateMap.add(
                'variable',
                new go.Node(nodeStyle({ type: go.Panel.Spot }))
                  .bindTwoWay(
                    'location',
                    'loc',
                    go.Point.parse,
                    go.Point.stringify
                  )
                  .add(
                    new go.Shape({
                      figure: 'Ellipse',
                      desiredSize: new go.Size(20, 20),
                      doubleClick: function(e, shape) {
                        var node = shape.part;
                        openFormulaModal(node.data.key, node.data.label || node.data.key, node.data.formula || '', 'formula', 'variable');
                      },
                    })
                    .set(shapeStyle())
                    .bind('fill', 'formula', function(f) {
                      return (f && f.trim()) ? '#a5d6a7' : '#f0f0f0';
                    }),
                    textStyle(
                      new go.TextBlock({
                        _isNodeLabel: true,
                        editable: true,
                        alignment: new go.Spot(0.5, 0.5, 0, 25),
                      })
                    ).bindTwoWay(
                      'alignment',
                      'label_offset',
                      go.Spot.parse,
                      go.Spot.stringify
                    )
                  )
              );

              // Link templates
              myDiagram.linkTemplateMap.add(
                'flow',
                new go.Link({ toShortLength: 8 }).add(
                  new go.Shape({ stroke: 'blue', strokeWidth: 5 }),
                  new go.Shape({
                    fill: 'blue',
                    stroke: null,
                    toArrow: 'Standard',
                    scale: 2.5,
                  })
                )
              );

              myDiagram.linkTemplateMap.add(
                'influence',
                new go.Link({
                  curve: go.Curve.Bezier,
                  toShortLength: 10,
                  curviness: 50,
                  reshapable: true,     // drag the midpoint handle to reposition the arc
                  resegmentable: true,  // double-click the link to add extra bend points
                  selectionObjectName: 'SHAPE',
                }).add(
                  new go.Shape({ name: 'SHAPE', stroke: 'green', strokeWidth: 1.5 }),
                  new go.Shape({
                    fill: 'green',
                    stroke: null,
                    toArrow: 'Standard',
                    scale: 1.5,
                  })
                )
              );
            }

            function clearDiagram() {
              if (!confirm('Clear the diagram? This cannot be undone.')) return;
              myDiagram.model = go.Model.fromJson('{ "class": "go.GraphLinksModel", "linkLabelKeysProperty": "labelKeys", "nodeDataArray": [], "linkDataArray": [] }');
              SD.nodeCounter = { stock: 0, cloud: 0, variable: 0, valve: 0 };
              try { localStorage.removeItem(STORAGE_KEY); } catch(e) {}
            }

            function setMode(mode, itemType) {
              myDiagram.startTransaction();
              var prevBtn = document.getElementById(SD.itemType + '_button');
              if (prevBtn) prevBtn.classList.remove('active');
              var nextBtn = document.getElementById(itemType + '_button');
              if (nextBtn) nextBtn.classList.add('active');
              SD.mode = mode;
              SD.itemType = itemType;
              if (mode === 'pointer') {
                myDiagram.allowLink = false;
                myDiagram.nodes.each((n) => (n.port.cursor = ''));
              } else if (mode === 'node') {
                myDiagram.allowLink = false;
                myDiagram.nodes.each((n) => (n.port.cursor = ''));
              } else if (mode === 'link') {
                myDiagram.allowLink = true;
                myDiagram.nodes.each((n) => (n.port.cursor = 'pointer'));
              }
              myDiagram.commitTransaction('mode changed');
            }

            // Show the diagram's model in JSON format that the user may edit
            function load() {
              var saved = null;
              try { saved = localStorage.getItem(STORAGE_KEY); } catch(e) {}

              var emptyModel = '{ "class": "go.GraphLinksModel", "linkLabelKeysProperty": "labelKeys", "nodeDataArray": [], "linkDataArray": [] }';
              myDiagram.model = go.Model.fromJson(saved || emptyModel);

              if (saved) {
                // Restore node counters so new nodes get unique keys
                var nodes = (JSON.parse(saved).nodeDataArray || []);
                nodes.forEach(function(n) {
                  var cat = n.category;
                  if (cat && SD.nodeCounter[cat] !== undefined) {
                    var num = parseInt((n.key || '').replace(/\D+/g, '')) || 0;
                    if (num > SD.nodeCounter[cat]) SD.nodeCounter[cat] = num;
                  }
                });
              }
            }

            function generateModel() {
              const modelJson = JSON.parse(myDiagram.model.toJson());
              const nodes = modelJson.nodeDataArray || [];
              const links = modelJson.linkDataArray || [];

              const stocks    = nodes.filter(function(n) { return n.category === 'stock'; });
              const variables = nodes.filter(function(n) { return n.category === 'variable'; });
              const valves    = nodes.filter(function(n) { return n.category === 'valve'; });
              const flows     = links.filter(function(l) { return l.category === 'flow'; });

              // map valve key → sanitized JS identifier
              var valveMap = {};
              valves.forEach(function(v) { valveMap[v.key] = toVarName(v.label || v.key); });

              // map sanitized valve name → formula
              var valveFormulaMap = {};
              valves.forEach(function(v) { valveFormulaMap[toVarName(v.label || v.key)] = v.formula || ''; });

              // determine inflows / outflows per stock
              var stockFlows = {};
              stocks.forEach(function(s) {
                stockFlows[s.key] = { label: toVarName(s.label || s.key), inflows: [], outflows: [] };
              });

              flows.forEach(function(flow) {
                var valveKey  = flow.labelKeys && flow.labelKeys[0];
                var flowName  = valveKey ? valveMap[valveKey] : toVarName(flow.text || 'flow');
                if (stockFlows[flow.from]) stockFlows[flow.from].outflows.push(flowName);
                if (stockFlows[flow.to])   stockFlows[flow.to].inflows.push(flowName);
              });

              // ---- build initialize() body with topological sort ----

              // Extract all this.xxx references from an expression
              function getInitDeps(expr) {
                if (!expr) return [];
                var deps = [];
                var re = /this\.([A-Za-z_][A-Za-z0-9_]*)/g;
                var m;
                while ((m = re.exec(expr)) !== null) deps.push(m[1]);
                return deps;
              }

              // Build a unified list of declarations: { key, line, deps[] }
              var allDecls = [];

              variables.forEach(function(v) {
                var lbl     = toVarName(v.label || v.key);
                var formula = v.formula;
                var line, deps;
                if (!formula || !formula.trim()) {
                  line = '    this.' + lbl + ' = 1;  // TODO: set value';
                  deps = [];
                } else if (!isDynamic(formula)) {
                  line = '    this.' + lbl + ' = ' + formula + ';';
                  deps = getInitDeps(formula);
                } else {
                  line = '    this.' + lbl + ' = 0;  // computed in update()';
                  deps = [];
                }
                allDecls.push({ key: lbl, line: line, deps: deps, kind: 'variable' });
              });

              stocks.forEach(function(s) {
                var lbl     = toVarName(s.label || s.key);
                var initVal = (s.initialValue !== undefined && String(s.initialValue).trim())
                  ? s.initialValue : '100';
                var comment = (s.initialValue !== undefined && String(s.initialValue).trim())
                  ? '' : '  // TODO: set initial value';
                var line = '    this.' + lbl + ' = ' + initVal + ';' + comment;
                var deps = getInitDeps(String(initVal));
                allDecls.push({ key: lbl, line: line, deps: deps, kind: 'stock' });
              });

              // DFS topological sort
              var declMap = {};
              allDecls.forEach(function(d) { declMap[d.key] = d; });

              var visited = {};
              var sorted  = [];

              function visitDecl(key) {
                if (visited[key]) return;
                visited[key] = true;
                var d = declMap[key];
                if (d) {
                  d.deps.forEach(function(dep) { visitDecl(dep); });
                  sorted.push(d);
                }
              }

              allDecls.forEach(function(d) { visitDecl(d.key); });

              // Output in topological order, adding section headers on kind transitions
              var initLines = [];
              var lastKind = null;
              sorted.forEach(function(d) {
                if (d.kind !== lastKind) {
                  if (lastKind !== null) initLines.push('');
                  initLines.push(d.kind === 'stock'
                    ? '    // Stocks (state variables)'
                    : '    // Parameters / auxiliary variables');
                  lastKind = d.kind;
                }
                initLines.push(d.line);
              });

              initLines.push('');
              initLines.push('    // Simulation settings');
              initLines.push('    this.dt = ' + modelSettings.dt + ';');
              initLines.push('    this.initTime = ' + modelSettings.initTime + ';');
              initLines.push('    this.finalTime = ' + modelSettings.finalTime + ';');

              // ---- build update() body ----
              var insideLoop = [];

              // Only dynamic variables (formula references this.xxx) go inside the loop
              var dynamicVars = variables.filter(function(v) {
                return v.formula && isDynamic(v.formula);
              });
              if (dynamicVars.length > 0) {
                insideLoop.push('      // Auxiliary variables (dynamic)');
                dynamicVars.forEach(function(v) {
                  insideLoop.push('      this.' + toVarName(v.label || v.key) + ' = ' + v.formula + ';');
                });
                insideLoop.push('');
              }

              var uniqueFlowNames = [];
              flows.forEach(function(flow) {
                var valveKey = flow.labelKeys && flow.labelKeys[0];
                var name = valveKey ? valveMap[valveKey] : toVarName(flow.text || 'flow');
                if (uniqueFlowNames.indexOf(name) === -1) uniqueFlowNames.push(name);
              });

              if (uniqueFlowNames.length > 0) {
                insideLoop.push('      // Flow rates');
                uniqueFlowNames.forEach(function(name) {
                  var formula = valveFormulaMap[name];
                  if (formula && formula.trim()) {
                    insideLoop.push('      const ' + name + ' = ' + formula + ';');
                  } else {
                    insideLoop.push('      const ' + name + ' = 0;  // TODO: define formula for ' + name);
                  }
                });
                insideLoop.push('');
              }

              insideLoop.push('      // Stock updates (Euler integration)');
              stocks.forEach(function(s) {
                var sf = stockFlows[s.key];
                var label = sf.label;
                var inStr  = sf.inflows.length  ? sf.inflows.join(' + ')  : null;
                var outStr = sf.outflows.length ? sf.outflows.join(' + ') : null;

                var net;
                if (inStr && outStr)  net = '(' + inStr + ') - (' + outStr + ')';
                else if (inStr)       net = inStr;
                else if (outStr)      net = '-(' + outStr + ')';
                else                  net = '0  // no flows connected';

                insideLoop.push('      this.' + label + ' += (' + net + ') * this.dt;');
              });

              // ---- reset stocks to initial values before each simulation run ----
              var resetLines = [];
              stocks.forEach(function(s) {
                var lbl     = toVarName(s.label || s.key);
                var initVal = (s.initialValue !== undefined && String(s.initialValue).trim())
                  ? s.initialValue : '100';
                resetLines.push('    this.' + lbl + ' = ' + initVal + ';');
              });

              var modelCode =
'const model = {\n' +
'  initialize: function () {\n' +
initLines.join('\n') + '\n' +
'  },\n' +
'  update: function () {\n' +
'    // Reset stocks to initial values before running simulation\n' +
resetLines.join('\n') + '\n' +
'\n' +
'    for (this.time = this.initTime; this.time < this.finalTime; this.time += this.dt) {\n' +
insideLoop.map(function(l){ return l; }).join('\n') + '\n' +
'    }\n' +
'  }\n' +
'};\n';

              // ---- build HTML panel ----
              var htmlLines = [];
              htmlLines.push('<p id="example">');
              htmlLines.push('  Final Time <span data-var="finalTime" class="TKAdjustableNumber" data-min="1" data-max="500"></span>');
              if (variables.length > 0) {
                variables.forEach(function(v) {
                  var lbl         = toVarName(v.label || v.key);
                  var displayName = v.label || v.key;
                  htmlLines.push('  ' + displayName + ' <span data-var="' + lbl + '" class="TKAdjustableNumber" data-min="0" data-max="10" data-step="0.01"></span>');
                });
              }
              htmlLines.push('</p>');
              stocks.forEach(function(s) {
                var lbl = toVarName(s.label || s.key);
                htmlLines.push("<div id='" + lbl + "_plot' class='plotly' data-plotly='[time, " + lbl + "]'></div>");
              });
              var htmlCode = htmlLines.join('\n');

              window.parent.postMessage({ type: 'forresterModel', code: modelCode, html: htmlCode }, '*');
            }

            window.addEventListener('DOMContentLoaded', init);
          </script>

          <div id='sample'>
            <div class='flex flex-row flex-wrap'>
              <!-- Icon toolbar -->
              <nav class='toolbar' style='width:100%'>

                <!-- Select -->
                <button id='pointer_button' class='tool-btn active' onclick="setMode('pointer','pointer');" title='Select / Move'>
                  <svg width='18' height='18' viewBox='0 0 24 24' fill='currentColor'><path d='M5 3l14 9-7 1.5-2.5 7z'/></svg>
                  Pointer
                </button>

                <div class='toolbar-sep'></div>

                <!-- Nodes -->
                <button id='stock_button' class='tool-btn' onclick="setMode('node','stock');" title='Add Stock (state variable)'>
                  <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><rect x='2' y='7' width='20' height='10' rx='2'/></svg>
                  Stock
                </button>
                <button id='cloud_button' class='tool-btn' onclick="setMode('node','cloud');" title='Add Cloud (source / sink)'>
                  <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round'><path d='M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 0 1 0 9z'/></svg>
                  Cloud
                </button>
                <button id='variable_button' class='tool-btn' onclick="setMode('node','variable');" title='Add Auxiliary Variable'>
                  <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5'><circle cx='12' cy='12' r='9'/><circle cx='12' cy='12' r='2.5' fill='currentColor' stroke='none'/></svg>
                  Variable
                </button>

                <div class='toolbar-sep'></div>

                <!-- Links -->
                <button id='flow_button' class='tool-btn' onclick="setMode('link','flow');" title='Draw Flow (rate)'>
                  <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><line x1='2' y1='12' x2='20' y2='12'/><polyline points='14 6 20 12 14 18'/></svg>
                  Flow
                </button>
                <button id='influence_button' class='tool-btn' onclick="setMode('link','influence');" title='Draw Influence arrow'>
                  <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M4 19C4 10 14 6 18 10'/><polyline points='14 7 18 10 15 14'/></svg>
                  Influence
                </button>

                <div class='toolbar-sep'></div>

                <!-- Actions -->
                <button id='generate_button' class='tool-btn btn-success' onclick='generateModel();' title='Generate model code from diagram'>
                  <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polygon points='13 2 3 14 12 14 11 22 21 10 12 10 13 2' fill='currentColor'/></svg>
                  Generate
                </button>
                <button id='clear_button' class='tool-btn btn-danger' onclick='clearDiagram();' title='Clear diagram'>
                  <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='3 6 5 6 21 6'/><path d='M19 6l-1 14H6L5 6'/><path d='M10 11v6M14 11v6'/><path d='M9 6V4h6v2'/></svg>
                  Clear
                </button>

                <div class='toolbar-sep'></div>

                <button id='settings_button' class='tool-btn' onclick='openSettingsModal();' title='Model Settings — configure time range and step size'>
                  <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'>
                    <line x1='4' y1='21' x2='4' y2='14'/><line x1='4' y1='10' x2='4' y2='3'/>
                    <line x1='12' y1='21' x2='12' y2='12'/><line x1='12' y1='8' x2='12' y2='3'/>
                    <line x1='20' y1='21' x2='20' y2='16'/><line x1='20' y1='12' x2='20' y2='3'/>
                    <line x1='1' y1='14' x2='7' y2='14'/><line x1='9' y1='8' x2='15' y2='8'/><line x1='17' y1='16' x2='23' y2='16'/>
                  </svg>
                  Settings
                  <span id='settings-hint' style='font-size:0.55rem; color:#4a88c8; font-family:monospace; margin-top:-2px;'>T=100 · dt=1</span>
                </button>
              </nav>
              <div
                id='myDiagramDiv'
                class='mb-2 mr-2'
                style='width: 100%; height: calc(100vh - 90px); border: solid 1px black'
              >
              </div>
              <div
                class='mb-2 h-fit w-fit flex-none rounded-md border-x border-t border-black'
                style='background-color: rgb(31, 73, 99)'
              >
                <div
                  class='rounded-b-md border-b border-black'
                  style='background-color: white; height: 0.5rem'
                >
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Formula editor popup -->
    <div id='formula-modal'>
      <div id='formula-modal-box'>
        <h3><span id='formula-modal-prefix'>Formula</span> for: <span id='formula-node-label'></span></h3>
        <div class='formula-vars-header'>
          <p class='formula-hint'>Click to insert:</p>
          <span id='formula-vars-count' class='formula-vars-count'></span>
        </div>
        <div class='formula-search-wrap'>
          <svg class='formula-search-icon' viewBox='0 0 16 16' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
            <circle cx='6.5' cy='6.5' r='4.5'/>
            <line x1='10' y1='10' x2='14' y2='14'/>
          </svg>
          <input
            id='formula-vars-search'
            type='text'
            placeholder='Filter variables…'
            autocomplete='off'
            spellcheck='false'
            aria-label='Filter variables'
            oninput='renderFormulaBadges(this.value)'
          />
        </div>
        <div id='formula-vars-container' role='list' aria-label='Available variables'></div>
        <textarea
          id='formula-input'
          spellcheck='false'
          autocomplete='off'
          placeholder='e.g. this.alpha * this.prey'
        ></textarea>
        <p class='formula-modal-hint'>Ctrl+Enter to save &nbsp;·&nbsp; Esc to cancel</p>
        <div class='formula-modal-footer'>
          <button type='button' class='formula-fx-btn' onclick='openFxModal()'>
            <svg width='13' height='13' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M4 7h16M4 12h10M4 17h7'/><circle cx='19' cy='17' r='3'/><path d='m21.5 19.5-1.5-1.5'/></svg>
            fx
          </button>
          <button onclick='closeFormulaModal()' style='background:#3c3c3c; color:#ccc;'>Cancel</button>
          <button onclick='saveFormula()' style='background:#0e7a3c; color:#fff;'>Save</button>
        </div>
      </div>
    </div>
    <!-- Model Settings popup -->
    <div id='settings-modal'>
      <div id='settings-modal-box'>
        <div class='settings-header'>
          <h3>
            <svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
              <line x1='4' y1='21' x2='4' y2='14'/><line x1='4' y1='10' x2='4' y2='3'/>
              <line x1='12' y1='21' x2='12' y2='12'/><line x1='12' y1='8' x2='12' y2='3'/>
              <line x1='20' y1='21' x2='20' y2='16'/><line x1='20' y1='12' x2='20' y2='3'/>
              <line x1='1' y1='14' x2='7' y2='14'/><line x1='9' y1='8' x2='15' y2='8'/><line x1='17' y1='16' x2='23' y2='16'/>
            </svg>
            Model Settings
          </h3>
          <button class='settings-close' onclick='closeSettingsModal()' aria-label='Close settings'>&times;</button>
        </div>
        <div class='settings-body'>
          <div class='settings-field'>
            <label class='settings-label' for='settings-init-time'>Initial Time</label>
            <input
              id='settings-init-time'
              type='number'
              class='settings-input'
              value='0'
              min='0'
              step='1'
              placeholder='0'
              onkeydown='if(event.key==="Enter") saveSettings(); if(event.key==="Escape") closeSettingsModal();'
            />
          </div>
          <div class='settings-field'>
            <label class='settings-label' for='settings-final-time'>Final Time</label>
            <input
              id='settings-final-time'
              type='number'
              class='settings-input'
              value='100'
              min='1'
              step='1'
              placeholder='100'
              onkeydown='if(event.key==="Enter") saveSettings(); if(event.key==="Escape") closeSettingsModal();'
            />
          </div>
          <div class='settings-field'>
            <label class='settings-label'>Time Step (dt)</label>
            <div class='settings-dt-group' role='group' aria-label='Time step'>
              <button type='button' class='settings-dt-btn' data-dt='2'        onclick='selectDt(2)'>2</button>
              <button type='button' class='settings-dt-btn' data-dt='1'        onclick='selectDt(1)'>1</button>
              <button type='button' class='settings-dt-btn' data-dt='0.5'      onclick='selectDt(0.5)'>0.5</button>
              <button type='button' class='settings-dt-btn' data-dt='0.25'     onclick='selectDt(0.25)'>0.25</button>
              <button type='button' class='settings-dt-btn' data-dt='0.125'    onclick='selectDt(0.125)'>0.125</button>
              <button type='button' class='settings-dt-btn' data-dt='0.0625'   onclick='selectDt(0.0625)'>0.0625</button>
              <button type='button' class='settings-dt-btn' data-dt='0.03125'  onclick='selectDt(0.03125)'>0.03125</button>
              <button type='button' class='settings-dt-btn' data-dt='0.015625' onclick='selectDt(0.015625)'>0.015625</button>
            </div>
          </div>
        </div>
        <div class='settings-footer'>
          <button onclick='closeSettingsModal()' style='background:#3c3c3c; color:#ccc;'>Cancel</button>
          <button onclick='saveSettings()' style='background:#0e7a3c; color:#fff;'>Apply</button>
        </div>
      </div>
    </div>

    <!-- fx function picker popup -->
    <div id='fx-modal'>
      <div id='fx-modal-box'>
        <div class='fx-modal-header'>
          <h3>Functions &mdash; DynaFlux Standard Library</h3>
          <button class='fx-modal-close' onclick='closeFxModal()' title='Close' aria-label='Close function picker'>&times;</button>
        </div>
        <div class='fx-search-wrap'>
          <svg class='fx-search-icon' viewBox='0 0 16 16' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
            <circle cx='6.5' cy='6.5' r='4.5'/><line x1='10' y1='10' x2='14' y2='14'/>
          </svg>
          <input
            id='fx-search'
            type='text'
            placeholder='Search functions… (DELAY, PULSE, SIN…)'
            autocomplete='off'
            spellcheck='false'
            aria-label='Search functions'
            oninput='renderFxList(this.value)'
            onkeydown='if(event.key==="Escape") closeFxModal()'
          />
        </div>
        <div id='fx-list' role='list' aria-label='Available functions'></div>
        <p class='fx-modal-hint'>Click a row or the Insert button — the snippet is added at the cursor position in your formula</p>
      </div>
    </div>
  </body>
</html>
